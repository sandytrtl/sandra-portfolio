import { useEffect, useRef, useState } from 'react';
import * as THREE from 'three';
import './Skills.css';

const ALL_SKILLS = [
  { name: 'React',       logo: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/react/react-original.svg',      color: '#61DAFB' },
  { name: 'TypeScript',  logo: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg', color: '#3178C6' },
  { name: 'JavaScript',  logo: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/javascript/javascript-original.svg', color: '#F7DF1E' },
  { name: 'HTML',        logo: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/html5/html5-original.svg',      color: '#E34F26' },
  { name: 'CSS',         logo: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/css3/css3-original.svg',        color: '#1572B6' },
  { name: 'Figma',       logo: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/figma/figma-original.svg',      color: '#F24E1E' },
  { name: 'Node.js',     logo: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/nodejs/nodejs-original.svg',    color: '#339933' },
  { name: 'Ionic',       logo: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/ionic/ionic-original.svg',      color: '#3880FF' },
  { name: 'Git',         logo: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/git/git-original.svg',          color: '#F05032' },
  { name: 'MySQL',       logo: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mysql/mysql-original.svg',      color: '#4479A1' },
  { name: 'PostgreSQL',  logo: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/postgresql/postgresql-original.svg', color: '#336791' },
  { name: 'GitHub',      logo: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/github/github-original.svg',   color: '#6e5494' },
  { name: 'Vite', logo: '/images/ViteLogo.svg',                                                      color: '#646CFF' },
  { name: 'UI Design',   logo: null, icon: '✦', color: '#9C775C' },
  { name: 'UX Research', logo: null, icon: '◎', color: '#C4A882' },
];

function ThreeTable({ isDark }) {
  const mountRef = useRef(null);
  const sceneRef = useRef(null);

  useEffect(() => {
    const mount = mountRef.current;
    if (!mount) return;

    const W = mount.clientWidth;
    const H = mount.clientHeight;

    // ── Renderer ──
    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setSize(W, H);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type = THREE.PCFSoftShadowMap;
    mount.appendChild(renderer.domElement);

    // ── Scene ──
    const scene = new THREE.Scene();
    sceneRef.current = scene;

    // ── Camera ──
    const camera = new THREE.PerspectiveCamera(45, W / H, 0.1, 100);
    camera.position.set(0, 5, 9);
    camera.lookAt(0, 0, 0);

    // ── Lights ──
    const ambient = new THREE.AmbientLight(0xffffff, isDark ? 0.5 : 0.7);
    scene.add(ambient);

    const dirLight = new THREE.DirectionalLight(0xfff0e0, isDark ? 1.0 : 1.3);
    dirLight.position.set(5, 10, 5);
    dirLight.castShadow = true;
    dirLight.shadow.mapSize.set(1024, 1024);
    scene.add(dirLight);

    const fillLight = new THREE.DirectionalLight(0x9C775C, 0.3);
    fillLight.position.set(-5, 3, -5);
    scene.add(fillLight);

    // ── Colour tokens ──
    const woodColor  = isDark ? 0x3a2510 : 0xc4956a;
    const legColor   = isDark ? 0x2a1a0a : 0xa07040;
    const topColor   = isDark ? 0x4a3018 : 0xd4a574;

    // ── Table top ──
    const topGeo = new THREE.BoxGeometry(7, 0.22, 4);
    const topMat = new THREE.MeshStandardMaterial({
      color: topColor,
      roughness: 0.45,
      metalness: 0.05,
    });
    const tableTop = new THREE.Mesh(topGeo, topMat);
    tableTop.position.y = 0;
    tableTop.castShadow = true;
    tableTop.receiveShadow = true;
    scene.add(tableTop);

    // Edge trim on table top
    const edgeGeo = new THREE.BoxGeometry(7.06, 0.06, 4.06);
    const edgeMat = new THREE.MeshStandardMaterial({ color: legColor, roughness: 0.3 });
    const edge = new THREE.Mesh(edgeGeo, edgeMat);
    edge.position.y = -0.08;
    scene.add(edge);

    // ── Legs ──
    const legGeo = new THREE.CylinderGeometry(0.1, 0.12, 2.2, 12);
    const legMat = new THREE.MeshStandardMaterial({ color: legColor, roughness: 0.5, metalness: 0.08 });
    const legPositions = [
      [-3.1, -1.2, -1.6],
      [ 3.1, -1.2, -1.6],
      [-3.1, -1.2,  1.6],
      [ 3.1, -1.2,  1.6],
    ];
    legPositions.forEach(([x, y, z]) => {
      const leg = new THREE.Mesh(legGeo, legMat);
      leg.position.set(x, y, z);
      leg.castShadow = true;
      scene.add(leg);
    });

    // Cross-braces
    const braceGeo = new THREE.CylinderGeometry(0.04, 0.04, 6.2, 8);
    const brace1 = new THREE.Mesh(braceGeo, legMat);
    brace1.rotation.z = Math.PI / 2;
    brace1.position.set(0, -1.8, -1.6);
    scene.add(brace1);
    const brace2 = new THREE.Mesh(braceGeo, legMat);
    brace2.rotation.z = Math.PI / 2;
    brace2.position.set(0, -1.8, 1.6);
    scene.add(brace2);

    // ── Floor shadow catcher ──
    const floorGeo = new THREE.PlaneGeometry(20, 20);
    const floorMat = new THREE.ShadowMaterial({ opacity: isDark ? 0.18 : 0.10 });
    const floor = new THREE.Mesh(floorGeo, floorMat);
    floor.rotation.x = -Math.PI / 2;
    floor.position.y = -2.35;
    floor.receiveShadow = true;
    scene.add(floor);

    // ── Skill cards on table ──
    const loader = new THREE.TextureLoader();
    const cardGroup = new THREE.Group();
    scene.add(cardGroup);

    const cardW = 0.9, cardH = 0.9, cardD = 0.06;
    const cols = 5, rows = 3;
    const startX = -(cols - 1) * (cardW + 0.18) / 2;
    const startZ = -(rows - 1) * (cardH + 0.18) / 2;

    ALL_SKILLS.slice(0, cols * rows).forEach((skill, i) => {
      const col = i % cols;
      const row = Math.floor(i / cols);

      const cardGeo = new THREE.BoxGeometry(cardW, cardD, cardH);
      const cardBg = isDark ? 0x2a1e14 : 0xfff4e6;
      const cardMat = new THREE.MeshStandardMaterial({
        color: cardBg,
        roughness: 0.55,
        metalness: 0.0,
      });

      const card = new THREE.Mesh(cardGeo, cardMat);
      card.position.set(
        startX + col * (cardW + 0.18),
        0.145,
        startZ + row * (cardH + 0.18)
      );
      card.castShadow = true;
      cardGroup.add(card);

      // Coloured top face
      const faceGeo = new THREE.PlaneGeometry(cardW - 0.08, cardH - 0.08);
      const faceColor = new THREE.Color(skill.color || '#9C775C');
      faceColor.multiplyScalar(0.25);
      const faceMat = new THREE.MeshStandardMaterial({
        color: faceColor,
        roughness: 0.6,
      });
      const face = new THREE.Mesh(faceGeo, faceMat);
      face.rotation.x = -Math.PI / 2;
      face.position.set(
        startX + col * (cardW + 0.18),
        0.175,
        startZ + row * (cardH + 0.18)
      );
      cardGroup.add(face);

      // Load icon texture if available
      if (skill.logo) {
        loader.load(skill.logo, (tex) => {
          tex.colorSpace = THREE.SRGBColorSpace;
          const iconGeo = new THREE.PlaneGeometry(0.42, 0.42);
          const iconMat = new THREE.MeshBasicMaterial({ map: tex, transparent: true });
          const icon = new THREE.Mesh(iconGeo, iconMat);
          icon.rotation.x = -Math.PI / 2;
          icon.position.set(
            startX + col * (cardW + 0.18),
            0.178,
            startZ + row * (cardH + 0.18) - 0.1
          );
          cardGroup.add(icon);
        });
      } else {
        // Fallback: small accent square
        const dotGeo = new THREE.PlaneGeometry(0.18, 0.18);
        const dotMat = new THREE.MeshStandardMaterial({ color: new THREE.Color(skill.color), roughness: 0.4 });
        const dot = new THREE.Mesh(dotGeo, dotMat);
        dot.rotation.x = -Math.PI / 2;
        dot.position.set(
          startX + col * (cardW + 0.18),
          0.178,
          startZ + row * (cardH + 0.18)
        );
        cardGroup.add(dot);
      }
    });

    // ── Drag to rotate ──
    let isDragging = false;
    let prevX = 0, prevY = 0;
    let rotX = 0.18, rotY = 0;
    let velX = 0, velY = 0;
    const tableGroup = new THREE.Group();
    scene.add(tableGroup);
    // Move all objects into tableGroup
    [tableTop, edge, floor, cardGroup].forEach(o => {
      scene.remove(o); tableGroup.add(o);
    });
    legPositions.forEach((_, idx) => {
      const leg = scene.children.find(c => c.position && Math.abs(c.position.x - legPositions[idx][0]) < 0.01 && Math.abs(c.position.z - legPositions[idx][2]) < 0.01);
    });
    // Re-add legs to tableGroup
    scene.children.slice().forEach(child => {
      if (child !== tableGroup && child !== ambient && child !== dirLight && child !== fillLight) {
        scene.remove(child);
        tableGroup.add(child);
      }
    });

    // Re-create scene cleanly
    scene.clear();
    scene.add(ambient, dirLight, fillLight);

    // Table group
    const tg = new THREE.Group();
    scene.add(tg);

    tg.add(tableTop, edge, floor);
    legPositions.forEach(([x, y, z]) => {
      const leg = new THREE.Mesh(legGeo, legMat);
      leg.position.set(x, y, z);
      leg.castShadow = true;
      tg.add(leg);
    });
    tg.add(brace1, brace2, cardGroup);

    const onPointerDown = (e) => {
      isDragging = true;
      prevX = e.clientX ?? e.touches?.[0]?.clientX ?? 0;
      prevY = e.clientY ?? e.touches?.[0]?.clientY ?? 0;
      velX = 0; velY = 0;
    };
    const onPointerMove = (e) => {
      if (!isDragging) return;
      const cx = e.clientX ?? e.touches?.[0]?.clientX ?? prevX;
      const cy = e.clientY ?? e.touches?.[0]?.clientY ?? prevY;
      velY = (cx - prevX) * 0.006;
      velX = (cy - prevY) * 0.003;
      rotY += velY;
      rotX = Math.max(-0.1, Math.min(0.55, rotX + velX));
      prevX = cx; prevY = cy;
    };
    const onPointerUp = () => { isDragging = false; };

    mount.addEventListener('mousedown', onPointerDown);
    window.addEventListener('mousemove', onPointerMove);
    window.addEventListener('mouseup', onPointerUp);
    mount.addEventListener('touchstart', onPointerDown, { passive: true });
    window.addEventListener('touchmove', onPointerMove, { passive: true });
    window.addEventListener('touchend', onPointerUp);

    // ── Animation loop ──
    let raf;
    const animate = () => {
      raf = requestAnimationFrame(animate);
      if (!isDragging) {
        velY *= 0.92;
        rotY += velY;
        // Auto-rotate slowly when idle
        rotY += 0.0018;
      }
      tg.rotation.y = rotY;
      tg.rotation.x = rotX;
      renderer.render(scene, camera);
    };
    animate();

    // ── Resize ──
    const onResize = () => {
      const w = mount.clientWidth, h = mount.clientHeight;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
    };
    window.addEventListener('resize', onResize);

    return () => {
      cancelAnimationFrame(raf);
      window.removeEventListener('mousemove', onPointerMove);
      window.removeEventListener('mouseup', onPointerUp);
      window.removeEventListener('touchmove', onPointerMove);
      window.removeEventListener('touchend', onPointerUp);
      window.removeEventListener('resize', onResize);
      renderer.dispose();
      if (mount.contains(renderer.domElement)) mount.removeChild(renderer.domElement);
    };
  }, [isDark]);

  return <div ref={mountRef} className="three-canvas" />;
}

export default function Skills() {
  const [isDark, setIsDark] = useState(
    () => document.documentElement.getAttribute('data-theme') === 'dark'
  );

  useEffect(() => {
    const obs = new MutationObserver(() => {
      setIsDark(document.documentElement.getAttribute('data-theme') === 'dark');
    });
    obs.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
    return () => obs.disconnect();
  }, []);

  return (
    <section id="skills" className="skills">
      <div className="skills-inner">
        <div className="skills-header reveal">
          <p className="section-label">Capabilities</p>
          <h2 className="skills-heading">
            What I bring<br />
            <span className="accent">to the table</span>
          </h2>
          <p className="skills-hint">
            <span className="hint-icon">⟳</span> Drag to rotate
          </p>
        </div>

        <div className="table-scene reveal reveal-delay-2">
          <ThreeTable isDark={isDark} />
        </div>

        {/* Skill name list below as reference */}
        <div className="skills-legend reveal reveal-delay-3">
          {ALL_SKILLS.map((s) => (
            <span key={s.name} className="legend-pill">
              {s.logo
                ? <img src={s.logo} alt={s.name} className="legend-logo" />
                : <span className="legend-icon">{s.icon}</span>
              }
              {s.name}
            </span>
          ))}
        </div>
      </div>
    </section>
  );
}
